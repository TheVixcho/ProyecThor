{
    "version": "0.0.1",
    "configurations": [
        {
            "name": "ProyecThor",
            "type": "cppdbg",
            "request": "launch",
            // Apuntamos al .exe generado por CMake en la carpeta build
            "program": "${workspaceFolder}/build/ProyecThor.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb.exe", 
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            // Esto intentará compilar antes de lanzar (requiere tasks.json)
            "preLaunchTask": "CMake: build"
        }
    ]
}